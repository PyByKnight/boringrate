{
  "_meta": {
    "purpose": "Durable structured dataset of primary-source SERFF rate filings \u2014 the analytical superset behind rate_changes.json. Feeds future charts/tools (liability-vs-physical-damage splits, rate trajectory, book-size weighting). rate_changes.json remains the tracker DISPLAY feed; this file is the RAW reference, joined by tracking #.",
    "schema": {
      "state": "2-letter",
      "carrier": "family name",
      "entity": "exact filing company",
      "tracking": "SERFF tracking #",
      "url": "filingSummary deep link",
      "product": "program name",
      "filing_type": "Prior Approval | File and Use",
      "disposition_date": "YYYY-MM-DD approval date",
      "effective_new": "YYYY-MM-DD new business | null",
      "effective_renewal": "YYYY-MM-DD renewals | null",
      "overall_pct": "signed approved overall rate-level impact (%)",
      "indicated_pct": "signed actuarially-indicated change (what they asked/justified) | null",
      "prior_revision_pct": "signed % of the carrier's previous revision (trajectory) | null",
      "written_premium": "total book $ for the program | null",
      "written_premium_change": "$ change from this filing | null",
      "affected": "policyholders or insured vehicles | null",
      "count_basis": "vehicles | policyholders",
      "coverage_changes": "per-coverage % {BI,PD,UM,MED,COMP,COLL,...} where the filing/PC-form exposed it | null (jacket-only filings don't break it out)",
      "premium_as_of": "valuation date of written_premium/affected (PC form Part 2 '@ MM/DD/YYYY' header) \u2014 REQUIRED for market-share-over-time | null if not captured",
      "recorded_date": "date WE logged this filing",
      "market_share_sc": "carrier's stated % share of the SC auto market (SC PC form field) | null; SC-specific, other states' forms may differ"
    },
    "coverage_note": "Per-coverage splits come from the PC form 'Part 1 / Requested Percent Changes by Type of Coverage' or a Rate Level Effect exhibit. Jacket-only zips (and image-based exhibits) don't expose them, so coverage_changes is null there. Capture Part 1 going forward when text-available \u2014 it powers the 'is your increase liability- or repair-driven' angle.",
    "last_updated": "2026-07-02",
    "refind": "Re-find any filing by searching its `tracking` number in SERFF Filing Access for that state (SERFF Tracking Number field) \u2014 works for '-G' numbers too, unlike the filingId deep link. We do NOT store individual attachment filenames; re-download the filing zip if a specific document (PC form, exhibit) is needed.",
